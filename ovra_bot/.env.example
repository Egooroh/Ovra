# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# OpenRouter API key for AI task parsing
OPENROUTER_API_KEY=
AI_MODEL=qwen/qwen3.7-plus

# Yandex SpeechKit — распознавание голосовых сообщений (OGG/Opus, ≤30 сек).
# Без этих ключей голосовые тихо игнорируются (бот ответит «не смог распознать»).
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Backend URL — в docker compose перезаписывается на http://app:8080
BACKEND_URL=http://localhost:8080

# Default workspace tenant ID
TENANT_ID=ws-demo

# Where to send task confirmations: "group" (default) or "pm"
CONFIRM_TARGET=group

# Your personal Telegram user ID (for PM confirmations)
PM_CHAT_ID=

# Proxy URL for Telegram API access (leave empty if not needed)
PROXY_URL=

# App secret (must match the backend APP_SECRET)
APP_SECRET=dev-only-change-me
