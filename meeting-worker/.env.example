# --- Database (та же БД что у Go-бэкенда) ---
# Локально:
DATABASE_URL="postgresql://ovra:ovra@localhost:5433/ovra?schema=public"
# Внутри docker compose (автоматически подставляется через docker-compose.yml):
# DATABASE_URL="postgresql://ovra:ovra@postgres:5432/ovra?schema=public"

# --- Claude (саммари встреч) ---
ANTHROPIC_API_KEY=

# --- Orchestrator ---
ORCH_POLL_MS=15000
ORCH_JOIN_LEAD_MS=60000
ORCH_MAX_CALLS=3
ORCH_HEARTBEAT_TIMEOUT_MS=45000
ORCH_MAX_ATTEMPTS=2

# --- Worker ---
WORKER_HEARTBEAT_MS=15000
WORKER_MAX_CALL_MS=10800000
WORKER_SILENCE_MS=300000

# --- Audio (PulseAudio sink -> ffmpeg) ---
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# --- Google Calendar (service account) ---
# GOOGLE_SA_JSON=/path/to/service-account-key.json
# GOOGLE_CALENDAR_IDS=primary,team@group.calendar.google.com

# --- Yandex Calendar (CalDAV) ---
# YANDEX_CALDAV_USERNAME=you@yandex.ru
# YANDEX_CALDAV_PASSWORD=your_app_password_here
# YANDEX_CALDAV_URL=https://caldav.yandex.ru

# --- Calendar watcher ---
CALENDAR_POLL_MS=300000
CALENDAR_LOOKAHEAD_MS=7200000

# --- Yandex SpeechKit (gRPC) ---
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_STT_ENDPOINT=stt.api.cloud.yandex.net:443
YANDEX_STT_LANG=ru-RU

# --- Display (для headless Xvfb) ---
# DISPLAY=:99

LOG_LEVEL=info
