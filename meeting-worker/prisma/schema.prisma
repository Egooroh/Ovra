// Prisma schema for the meeting-assistant worker.
// Source of truth for call state shared between orchestrator and forked workers.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the musl/openssl-3 target is for the Alpine image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Lifecycle of a single call. Maps 1:1 to the CallState machine in TS.
enum CallStatus {
  SCHEDULED // discovered by calendar-watcher, not yet picked up
  CLAIMED   // orchestrator reserved it, about to fork a worker
  JOINING   // worker launched, Playwright opening Telemost
  IN_CALL   // joined, audio capture + transcription running
  ENDING    // end-of-call detected, flushing transcript
  DONE       // finished cleanly
  FAILED    // unrecoverable error (see lastError)
  CANCELLED // meeting removed from calendar before join
}

/// A calendar connection owned by one organization (tenant).
/// One organization may have several (e.g. one per director's calendar).
/// The watcher polls every active account and tags created Calls with the
/// owning organizationId. Credentials are stored encrypted (AES-256-GCM);
/// the key lives only in the environment (CALENDAR_CRED_KEY), never here.
model CalendarAccount {
  id             String   @id @default(cuid())
  /// Opaque tenant id — matches the Go backend's organization id and the
  /// tenant_id sent with each meeting summary. Not an FK: the canonical
  /// Organization entity lives in the Go control plane, not in this DB.
  organizationId String
  /// "google" | "yandex".
  provider       String
  /// Human label for ops/logs, e.g. "Иван Петров / director@acme.ru".
  label          String?
  /// AES-256-GCM ciphertext of a provider-specific JSON credentials blob.
  credentials    String
  /// Google: calendar IDs to watch. Yandex: discovered automatically (may be empty).
  calendarIds    String[]
  /// Soft on/off switch so an account can be paused without deleting creds.
  active         Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, active])
}

/// One scheduled/known meeting the bot should attend.
model Call {
  id        String   @id @default(cuid())
  /// Stable id from the calendar source (dedupe key for the watcher).
  sourceId  String   @unique
  /// Owning tenant. Nullable for backward compatibility: pre-existing rows and
  /// the single-tenant env path (falls back to BACKEND_TENANT_ID downstream).
  organizationId String?
  /// Where the bot connects.
  joinUrl   String
  title     String?
  /// Calendar-provided times; the worker fills actual* on transitions.
  startsAt  DateTime
  endsAt    DateTime?

  status    CallStatus @default(SCHEDULED)

  /// Liveness for crash detection: orchestrator fences stale CLAIMED/JOINING/IN_CALL rows.
  workerPid     Int?
  claimedAt     DateTime?
  heartbeatAt   DateTime?
  joinedAt      DateTime?
  endedAt       DateTime?

  /// How many times we (re)launched a worker for this call.
  attempts  Int      @default(0)
  lastError String?

  transcript Transcript?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, startsAt])
  @@index([heartbeatAt])
  /// Fast per-tenant slot counting for the fairness cap in the orchestrator.
  @@index([organizationId, status])
}

/// Aggregated transcript for one call, assembled from streamed segments.
model Transcript {
  id        String   @id @default(cuid())
  callId    String   @unique
  call      Call     @relation(fields: [callId], references: [id], onDelete: Cascade)

  /// Full text, periodically rewritten as segments finalize.
  fullText  String   @default("")
  segments  TranscriptSegment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// One finalized chunk from the SpeechKit stream.
model TranscriptSegment {
  id           String   @id @default(cuid())
  transcriptId String
  transcript   Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)

  /// Offsets in seconds from call start.
  startMs   Int
  endMs     Int
  text      String
  /// Optional speaker label if diarization is available later.
  speaker   String?
  isFinal   Boolean  @default(true)

  createdAt DateTime @default(now())

  @@index([transcriptId, startMs])
}
