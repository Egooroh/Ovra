# Copy to .env and adjust. docker-compose reads these for all services.

# ── Go backend ────────────────────────────────────────────────────────────────
HTTP_ADDR=:8080
DATABASE_URL=postgres://ovra:ovra@localhost:5433/ovra?sslmode=disable
WORKSPACE_CONFIG=workspace.yaml
YOUGILE_API_TOKEN=
# Passphrase used to encrypt per-workspace YouGile tokens at rest. CHANGE in prod.
APP_SECRET=dev-only-change-me

# ── Telegram Mini App ─────────────────────────────────────────────────────────
# Bot token — also the HMAC key the backend uses to verify the signed initData
# every Mini App request carries. Required for /app/* to work (else it returns 503).
TELEGRAM_BOT_TOKEN=
# Directory of the built Mini App bundle served under /app/ (Vite `dist`).
MINIAPP_DIR=miniapp/dist

# Optional AI fallback for column mapping (OpenRouter, OpenAI-compatible).
# Leave OPENROUTER_API_KEY empty to disable AI — resolver uses dictionary+ordinal.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Task deduplication: pg_trgm similarity (0..1) above which a new task is treated
# as a possible duplicate. 0 disables dedup.
DEDUP_SIMILARITY=0.4

# Timezone for deadlines without explicit TZ (e.g. "by 18:00").
DEADLINE_TZ=Europe/Moscow

LOG_LEVEL=info

# ── Yandex SpeechKit (meeting transcription) ──────────────────────────────────
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_STT_ENDPOINT=stt.api.cloud.yandex.net:443
YANDEX_STT_LANG=ru-RU

# ── Yandex Calendar (CalDAV) ──────────────────────────────────────────────────
YANDEX_CALDAV_USERNAME=
YANDEX_CALDAV_PASSWORD=

# ── Google Calendar (service account JSON) ────────────────────────────────────
# Paste the full contents of your service account JSON file as a single line.
GOOGLE_SA_JSON=
GOOGLE_CALENDAR_IDS=
